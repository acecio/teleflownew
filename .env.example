# ── Telegram API (shared by both apps) ──────────────────────────────
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# ── TeleFlow AI (userbot) ────────────────────────────────────────────
# Get your session string by running: python -c "from telethon.sync import TelegramClient; from telethon.sessions import StringSession; c = TelegramClient(StringSession(), API_ID, API_HASH); c.start(); print(c.session.save())"
TELEGRAM_SESSION=your_session_string_here

# ── OpenRouter (AI replies) ──────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=stepfun/step-3.5-flash:free

# ── TeleFlow settings ────────────────────────────────────────────────
MESSAGES_PER_CHAT=30
MAX_CHATS=10

# ── VideoFlow (multi-user downloader) ───────────────────────────────
DB_PATH=videoflow.db
# YOUTUBE_COOKIES_FILE=/path/to/cookies.txt   # optional

# ── Server ───────────────────────────────────────────────────────────
PORT=8080
